NODE_ENV=development
PORT=3001

# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL=postgresql://picflux:picflux_password@localhost:5432/picflux

# JWT
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# Cloudflare R2
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=picflux

# CORS — Next.js dev server origin
FRONTEND_ORIGIN=http://localhost:3000
