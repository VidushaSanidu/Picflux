NODE_ENV=development
PORT=4001

# PostgreSQL
DATABASE_URL=postgresql://picflux:picflux_password@localhost:5432/picflux

# JWT
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# Cloudflare R2
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=picflux

# CORS — comma-separated list of allowed origins
PRB_ALLOWED_ORIGINS=http://localhost:3000

# API key for the ML processing service (Bearer token)
PRB_API_KEY=change_me_in_production

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4001/auth/google/callback

# Email / SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Daily job limit per user
DAILY_JOB_LIMIT=10

# ─── Leaderboard / Validator Auth ─────────────────────────────────────────────

# Maximum age (in seconds) of a validator report before it is rejected as stale.
# Prevents replay attacks. Default: 120.
SIGNATURE_MAX_AGE_SECONDS=120

# Set to "true" to skip sr25519 signature verification in local development.
# MUST be "false" in production.
ALLOW_UNSIGNED_DEV=true
